{
  "version": 2,
  "routes": [
    {
      "src": "/docs/(.*)",
      "dest": "/docs/$1"
    },
    {
      "src": "/swagger.json",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      },
      "dest": "/api/swagger.json"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://192.168.1.65:5000/api/$1"  // Укажите реальный URL вашего API
    }
  ]
}
