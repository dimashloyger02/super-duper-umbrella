{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "Test API"
  },
  "servers": [
    {
      "url": "http://192.168.1.65:5000/api",
      "description": "Основной сервер"
    }
  ],
  "tags": [
    {
      "name": "users",
      "description": "Операции с пользователями"
    },
    {
      "name": "monitoring",
      "description": "Операции с мониторингом"
    },
    {
      "name": "players",
      "description": "Операции с игроками Brawl Stars"
    }
  ],
  "paths": {
    "/users/all": {
      "get": {
        "summary": "Список всех пользователей",
        "tags": ["users"],
        "responses": { "200": { "description": "Успех" } }
      }
    },
    "/users/{user_id}": {
      "get": {
        "summary": "Данные пользователя",
        "tags": ["users"],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "200": { "description": "Успех" } }
      },
      "put": {
        "summary": "Обновление пользователя",
        "tags": ["users"],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "description": "Данные для обновления пользователя",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "role": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Успех" } }
      },
      "delete": {
        "summary": "Удаление пользователя",
        "tags": ["users"],
        "parameters": [
          {
            "name": "user_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "200": { "description": "Успех" } }
      }
    },
    "/users": {
      "post": {
        "summary": "Создание пользователя",
        "tags": ["users"],
        "requestBody": {
          "description": "Данные нового пользователя",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" },
                  "role": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Успешно создано" } }
      }
    },
    "/monitoring": {
      "get": {
        "summary": "Данные мониторинга",
        "tags": ["monitoring"],
        "responses": { "200": { "description": "Успех" } }
      },
      "put": {
        "summary": "Обновление мониторинга",
        "tags": ["monitoring"],
        "requestBody": {
          "description": "Данные для обновления мониторинга",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "metrics": {
                    "type": "object",
                    "description": "Метрики мониторинга"
                  },
                  "timestamp": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Успех" } }
      },
      "delete": {
        "summary": "Очистка мониторинга",
        "tags": ["monitoring"],
        "responses": { "200": { "description": "Успех" } }
      }
    },
    "/player/{tag}": {
      "get": {
        "summary": "Информация о игроке",
        "tags": ["players"],
        "parameters": [
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "Успех" } }
      }
    }
  }
}
